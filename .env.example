# Dashboard Backend Configuration

# ============ General Settings ============
DASHBOARD_SECRET=your_super_secret_key_change_this_in_production_12345

# ============ MQTT Settings ============
# Set USE_MQTT=true to enable MQTT data from ESP32
# Set USE_MQTT=false to use simulator only
USE_MQTT=false

# MQTT Broker Settings (for remote access, use cloud broker)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=esp32_user
MQTT_PASSWORD=esp32_password
MQTT_USE_TLS=false

# ============ Public MQTT Brokers (examples, use one of these) ============
# Option 1: HiveMQ (free public broker, no auth needed)
# MQTT_BROKER=broker.hivemq.com
# MQTT_PORT=1883
# MQTT_USER=
# MQTT_PASSWORD=
# MQTT_USE_TLS=false

# Option 2: test.mosquitto.org (free public broker)
# MQTT_BROKER=test.mosquitto.org
# MQTT_PORT=1883
# MQTT_USER=
# MQTT_PASSWORD=

# Option 3: CloudMQTT (free tier available at cloudmqtt.com)
# MQTT_BROKER=your_instance.cloudmqtt.com
# MQTT_PORT=10000
# MQTT_USER=your_username
# MQTT_PASSWORD=your_password
# MQTT_USE_TLS=true
